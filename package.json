{
	"name": "@obiguard/n8n-nodes-obiguard",
	"version": "1.0.0",
	"description": "Obiguard community node for n8n",
	"license": "MIT",
	"homepage": "https://obiguard.ai",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Obiguard",
		"email": "support@obiguard.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/obiguard/n8n-nodes-obiguard.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease",
		"test": "jest",
		"test:coverage": "jest --coverage"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/ObiguardApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/AIAgentTool/AiAgentTool.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/jest": "^30.0.0",
		"eslint": "9.32.0",
		"jest": "^30.4.2",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"ts-jest": "^29.4.11",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
